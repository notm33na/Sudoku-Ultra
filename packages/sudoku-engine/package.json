{
    "name": "@sudoku-ultra/sudoku-engine",
    "version": "0.0.1",
    "private": true,
    "description": "Core Sudoku puzzle engine — generation, solving, validation, hints",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "lint": "eslint src/ --ext .ts",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@sudoku-ultra/shared-types": "*"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.4.0"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/src"
        ],
        "testMatch": [
            "**/__tests__/**/*.test.ts",
            "**/*.test.ts"
        ],
        "collectCoverageFrom": [
            "src/**/*.ts",
            "!src/index.ts"
        ]
    }
}