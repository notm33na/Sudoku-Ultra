// ─── Prisma Schema ─── Sudoku Ultra Game Service ──────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  fcmToken         String?   @map("fcm_token")
  skillCluster     String?   @map("skill_cluster")      // Beginner | Casual | Intermediate | Advanced | Expert
  skillClusteredAt DateTime? @map("skill_clustered_at") // last time cluster was assigned
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  sessions          GameSession[]
  scores            Score[]
  streak            Streak?
  reEngagementQueue ReEngagementQueue[]

  @@map("users")
}

// ─── Puzzle ───────────────────────────────────────────────────────────────────

model Puzzle {
  id         String   @id @default(uuid())
  grid       Json     // Cell[][] as JSON
  solution   Json     // number[][] as JSON
  difficulty String   // super_easy | easy | medium | hard | super_hard | extreme
  clueCount  Int      @map("clue_count")
  createdAt  DateTime @default(now()) @map("created_at")

  sessions    GameSession[]
  scores      Score[]
  dailyPuzzle DailyPuzzle?

  @@map("puzzles")
}

// ─── Game Session ─────────────────────────────────────────────────────────────

model GameSession {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  puzzleId      String    @map("puzzle_id")
  currentGrid   Json      @map("current_grid") // Cell[][] as JSON
  status        String    @default("in_progress") // in_progress | completed | paused | abandoned
  difficulty    String
  timeElapsedMs Int       @default(0) @map("time_elapsed_ms")
  score         Int       @default(0)
  hintsUsed     Int       @default(0) @map("hints_used")
  errorsCount   Int       @default(0) @map("errors_count")
  startedAt     DateTime  @default(now()) @map("started_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  completedAt   DateTime? @map("completed_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  puzzle Puzzle @relation(fields: [puzzleId], references: [id])
  scores Score[]

  @@index([userId])
  @@index([puzzleId])
  @@index([status, completedAt])
  @@map("game_sessions")
}

// ─── Score ────────────────────────────────────────────────────────────────────

model Score {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  puzzleId    String   @map("puzzle_id")
  sessionId   String   @map("session_id")
  timeMs      Int      @map("time_ms")
  points      Int
  difficulty  String
  completedAt DateTime @default(now()) @map("completed_at")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  puzzle  Puzzle      @relation(fields: [puzzleId], references: [id])
  session GameSession @relation(fields: [sessionId], references: [id])

  @@index([userId])
  @@index([difficulty, points(sort: Desc)])
  @@map("scores")
}

// ─── Streak ───────────────────────────────────────────────────────────────────

model Streak {
  id                  String    @id @default(uuid())
  userId              String    @unique @map("user_id")
  currentStreak       Int       @default(0) @map("current_streak")
  longestStreak       Int       @default(0) @map("longest_streak")
  lastPlayedDate      DateTime? @map("last_played_date")
  freezeCount         Int       @default(0) @map("freeze_count")
  lastFreezeGrantedAt DateTime? @map("last_freeze_granted_at")
  milestonesAwarded   Json      @default("[]") @map("milestones_awarded")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

// ─── Daily Puzzle ─────────────────────────────────────────────────────────────

model DailyPuzzle {
  id         String   @id @default(uuid())
  puzzleId   String   @unique @map("puzzle_id")
  date       DateTime @unique @db.Date
  difficulty String

  puzzle Puzzle @relation(fields: [puzzleId], references: [id])

  @@map("daily_puzzles")
}

// ─── Re-Engagement Queue ──────────────────────────────────────────────────────
// Populated nightly by churn_risk_scorer Airflow DAG.
// Notification service polls this table and sends FCM pushes.

model ReEngagementQueue {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  churnProb  Float     @map("churn_prob")
  riskLevel  String    @map("risk_level") // medium | high | critical
  notified   Boolean   @default(false)
  notifiedAt DateTime? @map("notified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([notified, createdAt])
  @@map("re_engagement_queue")
}
