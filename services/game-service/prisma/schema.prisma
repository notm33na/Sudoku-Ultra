// ─── Prisma Schema ─── Sudoku Ultra Game Service ──────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  fcmToken         String?   @map("fcm_token")
  skillCluster     String?   @map("skill_cluster")      // Beginner | Casual | Intermediate | Advanced | Expert
  skillClusteredAt DateTime? @map("skill_clustered_at") // last time cluster was assigned
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  sessions          GameSession[]
  scores            Score[]
  streak            Streak?
  reEngagementQueue ReEngagementQueue[]
  playerRating      PlayerRating?
  lessonProgress      LessonProgress[]
  userBadges          UserBadge[]
  onboardingProgress  OnboardingProgress?
  sentFriendRequests     Friendship[]    @relation("FriendshipRequester")
  receivedFriendRequests Friendship[]    @relation("FriendshipAddressee")
  activityFeedEntries    ActivityFeed[]  @relation("ActivityFeedUser")
  actorActivities        ActivityFeed[]  @relation("ActivityFeedActor")

  @@map("users")
}

// ─── Puzzle ───────────────────────────────────────────────────────────────────

model Puzzle {
  id         String   @id @default(uuid())
  grid       Json     // Cell[][] as JSON
  solution   Json     // number[][] as JSON
  difficulty String   // super_easy | easy | medium | hard | super_hard | extreme
  clueCount  Int      @map("clue_count")
  createdAt  DateTime @default(now()) @map("created_at")

  sessions    GameSession[]
  scores      Score[]
  dailyPuzzle DailyPuzzle?

  @@map("puzzles")
}

// ─── Game Session ─────────────────────────────────────────────────────────────

model GameSession {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  puzzleId      String    @map("puzzle_id")
  currentGrid   Json      @map("current_grid") // Cell[][] as JSON
  status        String    @default("in_progress") // in_progress | completed | paused | abandoned
  difficulty    String
  timeElapsedMs Int       @default(0) @map("time_elapsed_ms")
  score         Int       @default(0)
  hintsUsed     Int       @default(0) @map("hints_used")
  errorsCount   Int       @default(0) @map("errors_count")
  startedAt     DateTime  @default(now()) @map("started_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  completedAt   DateTime? @map("completed_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  puzzle Puzzle @relation(fields: [puzzleId], references: [id])
  scores Score[]

  @@index([userId])
  @@index([puzzleId])
  @@index([status, completedAt])
  @@map("game_sessions")
}

// ─── Score ────────────────────────────────────────────────────────────────────

model Score {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  puzzleId    String   @map("puzzle_id")
  sessionId   String   @map("session_id")
  timeMs      Int      @map("time_ms")
  points      Int
  difficulty  String
  completedAt DateTime @default(now()) @map("completed_at")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  puzzle  Puzzle      @relation(fields: [puzzleId], references: [id])
  session GameSession @relation(fields: [sessionId], references: [id])

  @@index([userId])
  @@index([difficulty, points(sort: Desc)])
  @@map("scores")
}

// ─── Streak ───────────────────────────────────────────────────────────────────

model Streak {
  id                  String    @id @default(uuid())
  userId              String    @unique @map("user_id")
  currentStreak       Int       @default(0) @map("current_streak")
  longestStreak       Int       @default(0) @map("longest_streak")
  lastPlayedDate      DateTime? @map("last_played_date")
  freezeCount         Int       @default(0) @map("freeze_count")
  lastFreezeGrantedAt DateTime? @map("last_freeze_granted_at")
  milestonesAwarded   Json      @default("[]") @map("milestones_awarded")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

// ─── Daily Puzzle ─────────────────────────────────────────────────────────────

model DailyPuzzle {
  id         String   @id @default(uuid())
  puzzleId   String   @unique @map("puzzle_id")
  date       DateTime @unique @db.Date
  difficulty String

  puzzle Puzzle @relation(fields: [puzzleId], references: [id])

  @@map("daily_puzzles")
}

// ─── Re-Engagement Queue ──────────────────────────────────────────────────────
// Populated nightly by churn_risk_scorer Airflow DAG.
// Notification service polls this table and sends FCM pushes.

model ReEngagementQueue {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  churnProb  Float     @map("churn_prob")
  riskLevel  String    @map("risk_level") // medium | high | critical
  notified   Boolean   @default(false)
  notifiedAt DateTime? @map("notified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([notified, createdAt])
  @@map("re_engagement_queue")
}

// ─── Multiplayer Rating ───────────────────────────────────────────────────────

model PlayerRating {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  eloRating   Int       @default(1200) @map("elo_rating")
  wins        Int       @default(0)
  losses      Int       @default(0)
  lastMatchAt DateTime? @map("last_match_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eloRating(sort: Desc)])
  @@map("player_ratings")
}

// ─── Multiplayer Match History ────────────────────────────────────────────────

model MultiplayerMatch {
  id              String   @id @default(uuid())
  roomId          String   @map("room_id")
  winnerId        String   @map("winner_id")
  loserId         String   @map("loser_id")
  winnerEloBefore Int      @map("winner_elo_before")
  winnerEloAfter  Int      @map("winner_elo_after")
  loserEloBefore  Int      @map("loser_elo_before")
  loserEloAfter   Int      @map("loser_elo_after")
  endReason       String   @map("end_reason")
  durationMs      Int      @map("duration_ms")
  difficulty      String
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([winnerId])
  @@index([loserId])
  @@index([createdAt(sort: Desc)])
  @@map("multiplayer_matches")
}

// ─── Gamified Lessons ─────────────────────────────────────────────────────────

model LessonProgress {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  lessonId      String    @map("lesson_id")
  stepsComplete Int       @default(0) @map("steps_complete")
  completed     Boolean   @default(false)
  completedAt   DateTime? @map("completed_at")
  xpAwarded     Int       @default(0) @map("xp_awarded")
  startedAt     DateTime  @default(now()) @map("started_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("lesson_progress")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id")
  awardedAt DateTime @default(now()) @map("awarded_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// ─── Onboarding ───────────────────────────────────────────────────────────────

model OnboardingProgress {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  stepsComplete Int       @default(0) @map("steps_complete")
  completed     Boolean   @default(false)
  completedAt   DateTime? @map("completed_at")
  skipped       Boolean   @default(false)
  startedAt     DateTime  @default(now()) @map("started_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_progress")
}

// ─── Friends ──────────────────────────────────────────────────────────────────
// status: pending | accepted | declined | blocked

model Friendship {
  id          String   @id @default(uuid())
  requesterId String   @map("requester_id")
  addresseeId String   @map("addressee_id")
  status      String   @default("pending") // pending | accepted | declined | blocked
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
  @@map("friendships")
}

// ─── Activity Feed ────────────────────────────────────────────────────────────
// type: puzzle_completed | badge_earned | lesson_completed | friend_added

model ActivityFeed {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")   // owner of the activity (whose timeline it appears on)
  actorId   String   @map("actor_id")  // user who performed the action
  type      String                     // puzzle_completed | badge_earned | lesson_completed | friend_added
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user  User @relation("ActivityFeedUser",  fields: [userId],  references: [id], onDelete: Cascade)
  actor User @relation("ActivityFeedActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([actorId])
  @@map("activity_feed")
}
