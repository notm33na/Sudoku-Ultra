{
    "name": "@sudoku-ultra/notifications",
    "version": "0.0.1",
    "private": true,
    "description": "Notification service — push notifications, email, in-app alerts",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "start": "node dist/index.js",
        "lint": "eslint src/ --ext .ts",
        "test": "jest --passWithNoTests",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.18.0",
        "firebase-admin": "^12.3.0",
        "helmet": "^7.1.0",
        "morgan": "^1.10.0",
        "pg": "^8.12.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.0",
        "@types/morgan": "^1.9.9",
        "@types/pg": "^8.11.6",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.0"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node"
    }
}