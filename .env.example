# ──────────────────────────────────────────────────────────────────────────────
# Sudoku Ultra — Environment Variables Template
# Copy to .env.local and fill in actual values
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sudoku:sudoku_dev_password@localhost:5432/sudoku_ultra
MONGODB_URI=mongodb://sudoku:sudoku_dev_password@localhost:27017/sudoku_ultra
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Services ───────────────────────────────────────────────────────────────────
GAME_SERVICE_PORT=3001
MULTIPLAYER_PORT=3002
ML_SERVICE_PORT=3003
NOTIFICATIONS_PORT=3004

# ── External APIs ─────────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# ── Observability ──────────────────────────────────────────────────────────────
