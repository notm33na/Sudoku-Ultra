{
    "name": "@sudoku-ultra/mobile",
    "version": "0.0.1",
    "private": true,
    "description": "Sudoku Ultra — React Native mobile app (Expo)",
    "main": "expo-router/entry",
    "scripts": {
        "start": "expo start",
        "dev": "expo start --dev-client",
        "android": "expo start --android",
        "ios": "expo start --ios",
        "web": "expo start --web",
        "build": "echo 'Mobile build handled by EAS — skipping in turbo'",
        "lint": "eslint . --ext .ts,.tsx",
        "test": "jest --passWithNoTests",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@react-navigation/bottom-tabs": "^6.5.0",
        "@react-navigation/native": "^6.1.0",
        "@react-navigation/native-stack": "^6.9.0",
        "@sudoku-ultra/shared-types": "*",
        "@sudoku-ultra/sudoku-engine": "*",
        "expo": "~50.0.0",
        "expo-asset": "~10.0.0",
        "expo-camera": "~14.0.0",
        "expo-file-system": "~16.0.0",
        "expo-status-bar": "~1.11.0",
        "nativewind": "^2.0.0",
        "onnxruntime-react-native": "^1.17.0",
        "react": "18.2.0",
        "react-native": "0.73.0",
        "react-native-safe-area-context": "4.8.0",
        "react-native-screens": "~3.29.0",
        "zustand": "^4.5.0"
    },
    "devDependencies": {
        "@babel/core": "^7.20.0",
        "@types/jest": "^29.5.0",
        "@types/react": "~18.2.45",
        "jest": "^29.7.0",
        "react-test-renderer": "18.2.0",
        "tailwindcss": "3.3.2",
        "typescript": "^5.4.0"
    },
    "jest": {
        "preset": "jest-expo"
    }
