{
    "name": "@sudoku-ultra/web-admin",
    "version": "0.1.0",
    "private": true,
    "description": "Sudoku Ultra — Admin dashboard (D3 analytics, skill clustering, user management)",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "start": "node dist/server.js",
        "lint": "eslint src/ --ext .ts",
        "test": "jest --passWithNoTests",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "express": "^4.18.0",
        "cors": "^2.8.5",
        "helmet": "^7.1.0",
        "pg": "^8.12.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/cors": "^2.8.17",
        "@types/node": "^20.14.0",
        "@types/pg": "^8.11.6",
        "typescript": "^5.4.0",
        "ts-node-dev": "^2.0.0"
    }
}
